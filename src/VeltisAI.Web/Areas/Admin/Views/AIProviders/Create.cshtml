@model VeltisAI.Web.Areas.Admin.ViewModels.AIProviders.AIProviderFormViewModel
@using VeltisAI.Domain.Enums

@{
    ViewData["Title"] = "Novo Provedor";
}

<h1>Novo Provedor de IA</h1>

<form asp-action="Create" method="post" class="card shadow-sm mt-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="DisplayName" class="form-label">Nome de Exibição</label>
                <input asp-for="DisplayName" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Name" class="form-label">Nome Interno</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Type" class="form-label">Tipo</label>
                <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<AIProviderType>()"></select>
            </div>

            <div class="col-md-6">
                <label asp-for="BaseUrl" class="form-label">Base URL</label>
                <input asp-for="BaseUrl" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="ApiKey" class="form-label">API Key</label>
                <input asp-for="ApiKey" class="form-control" type="password" />
            </div>

            <div class="col-md-3">
                <label asp-for="Priority" class="form-label">Prioridade</label>
                <input asp-for="Priority" class="form-control" />
            </div>

            <div class="col-md-3">
                <label asp-for="TimeoutSeconds" class="form-label">Timeout</label>
                <input asp-for="TimeoutSeconds" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="RetryCount" class="form-label">Tentativas</label>
                <input asp-for="RetryCount" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="OrganizationId" class="form-label">Organization ID</label>
                <input asp-for="OrganizationId" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="ApiVersion" class="form-label">Versão da API</label>
                <input asp-for="ApiVersion" class="form-control" />
            </div>

            <div class="col-12 d-flex gap-4 mt-3">
                <div class="form-check">
                    <input asp-for="SupportsStreaming" class="form-check-input" />
                    <label asp-for="SupportsStreaming" class="form-check-label">Streaming</label>
                </div>

                <div class="form-check">
                    <input asp-for="SupportsVision" class="form-check-input" />
                    <label asp-for="SupportsVision" class="form-check-label">Visão</label>
                </div>

                <div class="form-check">
                    <input asp-for="SupportsAudio" class="form-check-input" />
                    <label asp-for="SupportsAudio" class="form-check-label">Áudio</label>
                </div>

                <div class="form-check">
                    <input asp-for="Active" class="form-check-input" />
                    <label asp-for="Active" class="form-check-label">Ativo</label>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
        <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
</form>