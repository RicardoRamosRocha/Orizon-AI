@model IEnumerable<VeltisAI.Domain.Entities.AIProvider>

@{
    ViewData["Title"] = "Provedores de IA";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Provedores de IA</h1>
        <p class="text-muted">Gerencie os provedores de inteligência artificial disponíveis na plataforma.</p>
    </div>
    <a asp-area="Admin" asp-controller="AIProviders" asp-action="Create" class="btn btn-primary">
        Novo Provedor
    </a>
    <a href="/Admin/AIProviders/Create" class="btn btn-primary">
    Novo Provedor
</a>

</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Base URL</th>
                    <th>Prioridade</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DisplayName</td>
                    <td>@item.Type</td>
                    <td>@item.BaseUrl</td>
                    <td>@item.Priority</td>
                    <td>
                        @if (item.Active)
                        {
                            <span class="badge bg-success">Ativo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inativo</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>