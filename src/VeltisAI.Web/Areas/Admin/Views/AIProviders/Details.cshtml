@model VeltisAI.Domain.Entities.AIProvider

@{
    ViewData["Title"] = "Detalhes do Provedor";
}

<h1>Detalhes do Provedor</h1>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.DisplayName</dd>

            <dt class="col-sm-3">Tipo</dt>
            <dd class="col-sm-9">@Model.Type</dd>

            <dt class="col-sm-3">Base URL</dt>
            <dd class="col-sm-9">@Model.BaseUrl</dd>

            <dt class="col-sm-3">Prioridade</dt>
            <dd class="col-sm-9">@Model.Priority</dd>

            <dt class="col-sm-3">Timeout</dt>
            <dd class="col-sm-9">@Model.TimeoutSeconds segundos</dd>

            <dt class="col-sm-3">Tentativas</dt>
            <dd class="col-sm-9">@Model.RetryCount</dd>

            <dt class="col-sm-3">Recursos</dt>
            <dd class="col-sm-9">
                Streaming: @Model.SupportsStreaming |
                Visão: @Model.SupportsVision |
                Áudio: @Model.SupportsAudio
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@(Model.Active ? "Ativo" : "Inativo")</dd>
        </dl>
    </div>

    <div class="card-footer d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    </div>
</div>