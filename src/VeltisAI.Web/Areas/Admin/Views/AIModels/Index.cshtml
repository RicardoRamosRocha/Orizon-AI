@model IEnumerable<VeltisAI.Domain.Entities.AIModel>

@{
    ViewData["Title"] = "Modelos de IA";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Modelos de IA</h2>
        <p class="text-muted">Gerencie os modelos disponíveis.</p>
    </div>

    <a asp-area="Admin"
       asp-controller="AIModels"
       asp-action="Create"
       class="btn btn-primary">
        Novo Modelo
    </a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Identifier</th>
            <th>Provedor</th>
            <th>Modalidade</th>
            <th>Status</th>
            <th width="180"></th>
        </tr>
    </thead>

    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Identifier</td>
            <td>@item.AIProvider?.DisplayName</td>
            <td>@item.Modalities</td>

            <td>
                @if (item.Active)
                {
                    <span class="badge bg-success">Ativo</span>
                }
                else
                {
                    <span class="badge bg-danger">Inativo</span>
                }
            </td>

            <td>
                <a asp-action="Edit"
                   asp-route-id="@item.Id"
                   class="btn btn-sm btn-warning">
                    Editar
                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.Id"
                   class="btn btn-sm btn-danger">
                    Excluir
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>