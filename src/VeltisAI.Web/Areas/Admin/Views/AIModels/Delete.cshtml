@model VeltisAI.Domain.Entities.AIModel

@{
    ViewData["Title"] = "Excluir Modelo de IA";
}

<h2>Excluir Modelo de IA</h2>

<div class="alert alert-danger">
    Tem certeza que deseja excluir este modelo?
</div>

<dl class="row">
    <dt class="col-sm-3">Nome</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Identificador</dt>
    <dd class="col-sm-9">@Model.Identifier</dd>

    <dt class="col-sm-3">Provedor</dt>
    <dd class="col-sm-9">@Model.AIProvider?.DisplayName</dd>

    <dt class="col-sm-3">Modalidade</dt>
    <dd class="col-sm-9">@Model.Modalities</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @if (Model.Active)
        {
            <span class="badge bg-success">Ativo</span>
        }
        else
        {
            <span class="badge bg-secondary">Inativo</span>
        }
    </dd>
</dl>

<form asp-area="Admin"
      asp-controller="AIModels"
      asp-action="Delete"
      method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Excluir
    </button>

    <a asp-area="Admin"
       asp-controller="AIModels"
       asp-action="Index"
       class="btn btn-secondary">
        Cancelar
    </a>
</form>